# ------- Public (servi au navigateur) -------
NEXT_PUBLIC_APP_NAME="souche-next-front-app"
NEXT_PUBLIC_API_URL="http://localhost:7700/api/v1"
NEXT_PUBLIC_MAX_ATTEMPTS="5"
NEXT_PUBLIC_LOCKOUT_SEC="30"

# Paramètres de session
NEXT_PUBLIC_INACTIVITY_TIMEOUT="30"  # Minutes d'inactivité avant déconnexion (défaut: 30)
NEXT_PUBLIC_TOKEN_CHECK_INTERVAL="60"  # Secondes entre chaque vérification du token (défaut: 60)
NEXT_PUBLIC_SESSION_WARNING_TIME="5"  # Minutes avant expiration pour afficher l'avertissement (défaut: 5)

# ------- Serveur ONLY (non exposés) -------
API_URL="http://localhost:7700/api/v1"
DATABASE_URL="postgres://user:__CHANGE_ME__@localhost:5432/myapp"
JWT_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----\n...\n-----END EC PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_ACCESS_TTL="900"   # 15 min (secondes)
JWT_REFRESH_TTL="604800" # 7 jours
COOKIE_SECRET="c1c70c75b96fcd66a8e447c08d90eef518427437a535c174832c1603a151210f"

# ------- GDPR -------
PII_HASH_SALT="__16_BYTES_HEX__"

# Turnstile (Cloudflare)
TURNSTILE_SECRET_KEY=0x4AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
NEXT_PUBLIC_TURNSTILE_SITE_KEY="1x00000000000000000000AA"

# ------- Monitoring & Logging (Optional - Production) -------
# Sentry for error tracking
# NEXT_PUBLIC_SENTRY_DSN="https://your-sentry-dsn@sentry.io/project-id"
# SENTRY_AUTH_TOKEN="__SENTRY_AUTH_TOKEN__"
# SENTRY_ORG="your-org"
# SENTRY_PROJECT="your-project"

# Performance monitoring
# NEXT_PUBLIC_ENABLE_ANALYTICS="false"

# Log level (error, warn, info, debug)
# LOG_LEVEL="info"
